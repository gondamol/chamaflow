# Supabase (multi-device sync) — create a free project, run supabase/schema.sql
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# M-Pesa Daraja (STK Push) — server-only on Vercel. Never put secrets in VITE_*.
# Leave empty to use demo STK mode in the app.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
# Public HTTPS callback (optional for sandbox demo)
MPESA_CALLBACK_URL=
